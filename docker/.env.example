# Copy this file to .env (next to docker-compose.*.yml) and adjust values.

# Container timezone (e.g. Europe/Moscow, America/New_York).
TZ=Europe/Moscow

# Published HTTP port on host.
ROPDS_PORT=8081

# Host path mounted to /library inside container (RW).
# Absolute path is recommended in production.
ROPDS_LIBRARY_ROOT=./library

# Admin bootstrap password (used by entrypoint).
ROPDS_ADMIN_PASSWORD=change-me-now

# If true, admin init runs once and creates marker in /library/.ropds_admin_initialized
ROPDS_ADMIN_INIT_ONCE=true

# Maximum seconds to wait for postgres/mysql availability.
ROPDS_DB_WAIT_TIMEOUT=60

# Database credentials for bundled DB scenarios (postgres/mysql sibling).
# Must match the connection URL in the corresponding config/*.toml file.
# DB_NAME=ropds
# DB_USER=ropds
# DB_PASSWORD=ropds_change_me
# DB root password (MySQL only)
# DB_ROOT_PASSWORD=root_change_me

# Optional explicit DB host/port overrides for wait-for-db.sh.
# Useful for complex connection URLs or if URL parsing is undesirable.
# ROPDS_DB_HOST=postgres
# ROPDS_DB_PORT=5432

# Container image reference. The default is the GHCR image.
# IMPORTANT: ROPDS_IMAGE is the repository ONLY (no tag, no colon).
# Use ROPDS_VERSION for the tag. A value like `repo:tag` here will
# produce `repo:tag:latest` at runtime and fail to pull.
# ROPDS_IMAGE=ghcr.io/dshein-alt/ropds
# ROPDS_IMAGE=docker.io/dsheinalt/ropds

# Pin a specific version instead of following `latest`.
# ROPDS_VERSION=latest

# Path to the ROPDS config file on the host (relative to this .env file).
# ROPDS_CONFIG_FILE=./config.toml
